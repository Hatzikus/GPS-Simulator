	};
	enum eBT_STATE
	{
		ebtWAITING_MAGIC_NUMBER			= 0,
		ebtWAITING_VERSION				= 1,
		ebtWAITING_LENGTH				= 2,
		ebtWAITING_DATA					= 3
	};
	public struct structBT_DATA
	{
		public int						iLengthGot;
		public byte[]					byteArray;
		public byte						ui8MagicNumber;
		public byte						ui8Version;
		public byte						ui8Length;
		public byte						ui8Bits;
		public double					dLatitude;
		public double					dLongitude;
		public double					dHeight;
		public double					dMSL;
		public UInt32					ui32HAcc;			// Horizontal accuracy estimate: mm * 0.1
		public UInt32					ui32VAcc;			// Vertical accuracy estimate: mm * 0.1
		public byte						ui8FixType;
		public byte						ui8NumSV;
		public UInt16					ui16CRC;
		public DateTime					datTimeStamp;
	};
