		private void frmMain_OnTimer(object sender, EventArgs e)
		{
			int				iIndex;
			int				iData;
			string			strName;

			btSearchBluetooth.Enabled = !m_bSearching;
			if (m_listNewClients != null && !m_bSearching)
			{
				for (int i = 0; i < m_listNewClients.Count; ++i)
				{
					strName = m_listNewClients[i].strName + (m_listNewClients[i].bConnected ? " (Verbunden)" : "");
					iIndex = lbDevices.Items.Add(strName);
				}
				m_listClients = m_listNewClients;
				m_listNewClients = null;
			}

			if (m_ClientStream != null)
			{
				while (m_ClientStream.DataAvailable)
				{
					iData = m_ClientStream.ReadByte();
					if (iData >= 0)
					{
						switch (m_eBT_State)
						{
							case eBT_STATE.ebtWAITING_MAGIC_NUMBER:
								if (m_structBT_Data.byteArray != null)
									m_structBT_Data.byteArray = null;
								m_structBT_Data.iLengthGot = 0;

								if (iData == m_structBT_Data.ui8MagicNumber)
								{
									m_eBT_State = eBT_STATE.ebtWAITING_VERSION;
									if (m_iTrash_Length > 0)
									{
										System.Diagnostics.Trace.WriteLine(string.Format("Trash Data Length={0}", m_iTrash_Length));
										m_iTrash_Length = 0;
									}
								}
								else
								{
									++m_iTrash_Length;
								}
								break;
							case eBT_STATE.ebtWAITING_VERSION:
								m_structBT_Data.ui8Version = (byte)iData;
								m_eBT_State = eBT_STATE.ebtWAITING_LENGTH;
								break;
							case eBT_STATE.ebtWAITING_LENGTH:
								m_structBT_Data.ui8Length = (byte)iData;
								m_structBT_Data.iLengthGot = 3;
								if (m_structBT_Data.ui8Length < 4)
									m_eBT_State = eBT_STATE.ebtWAITING_MAGIC_NUMBER;
								m_structBT_Data.byteArray = new byte[m_structBT_Data.ui8Length];
								m_structBT_Data.byteArray[0] = m_structBT_Data.ui8MagicNumber;
								m_structBT_Data.byteArray[1] = m_structBT_Data.ui8Version;
								m_structBT_Data.byteArray[2] = m_structBT_Data.ui8Length;
								m_eBT_State = eBT_STATE.ebtWAITING_DATA;
								break;
							case eBT_STATE.ebtWAITING_DATA:
								m_structBT_Data.byteArray[m_structBT_Data.iLengthGot] = (byte)iData;
								++m_structBT_Data.iLengthGot;
								if (m_structBT_Data.iLengthGot >= m_structBT_Data.ui8Length)
								{
									m_structBT_Data.ui8Bits = m_structBT_Data.byteArray[3];

									UInt16		ui16Year;
									byte		byteValid;
									byte		byteMonth;
									byte		byteDay;
									byte		byteHour;
									byte		byteMinute;
									byte		byteSecond;
									Int32		i32Nanosecond;
									UInt16		ui16CRC;

									ui16Year = BitConverter.ToUInt16(m_structBT_Data.byteArray, 4);
									byteValid = m_structBT_Data.byteArray[6];
									byteMonth = m_structBT_Data.byteArray[7];
									byteDay = m_structBT_Data.byteArray[8];
									byteHour = m_structBT_Data.byteArray[9];
									byteMinute = m_structBT_Data.byteArray[10];
									byteSecond = m_structBT_Data.byteArray[11];
									i32Nanosecond = BitConverter.ToInt16(m_structBT_Data.byteArray, 12);

									if (ui16Year != 0 && byteMonth != 0 && byteDay != 0)
										m_structBT_Data.datTimeStamp = new DateTime(ui16Year, byteMonth, byteDay, byteHour, byteMinute, byteSecond, (int)Math.Round(i32Nanosecond * 0.000001));
									else
										m_structBT_Data.datTimeStamp = DateTime.MinValue;

									m_structBT_Data.dLatitude = BitConverter.ToDouble(m_structBT_Data.byteArray, 16);
									m_structBT_Data.dLongitude = BitConverter.ToDouble(m_structBT_Data.byteArray, 24);
									m_structBT_Data.dHeight = BitConverter.ToDouble(m_structBT_Data.byteArray, 32);
									m_structBT_Data.dMSL = BitConverter.ToDouble(m_structBT_Data.byteArray, 40);

									m_structBT_Data.ui32HAcc = BitConverter.ToUInt32(m_structBT_Data.byteArray, 48);
									m_structBT_Data.ui32VAcc = BitConverter.ToUInt32(m_structBT_Data.byteArray, 52);

									m_structBT_Data.ui8FixType = m_structBT_Data.byteArray[56];
									m_structBT_Data.ui8NumSV = m_structBT_Data.byteArray[57];

									m_structBT_Data.ui16CRC = BitConverter.ToUInt16(m_structBT_Data.byteArray, 58);

									// Komischerweise wird die Struct auf 8 aufgerundet übertragen!!!
									// nein nicht komisch - hinten 4 Byte Reserve auf 64
									ui16CRC = Crc16.CRC16_Calc(m_structBT_Data.byteArray, 58);

									if (ui16CRC != m_structBT_Data.ui16CRC)
									{
										++m_ui32CRC_Error;
										tbCRC_Error.Text = string.Format("{0}", m_ui32CRC_Error);
									}
									else
									{
										userControl11.SetCurrentPosition(m_structBT_Data.dLatitude, m_structBT_Data.dLongitude, m_structBT_Data.dMSL);
										userControl12.SetCurrentPosition(m_structBT_Data.dLatitude, m_structBT_Data.dLongitude, m_structBT_Data.dMSL);

										tbLatitude.Text = string.Format("{0}", m_structBT_Data.dLatitude);
										tbLongitude.Text = string.Format("{0}", m_structBT_Data.dLongitude);
										tbHeight.Text = string.Format("{0}", m_structBT_Data.dHeight);
										tbMSL.Text = string.Format("{0}", m_structBT_Data.dMSL);

										for (int i = 0; i < cbFixType.Items.Count; i++)
										{
											fixType item = cbFixType.Items[i] as fixType;
											if (item != null && item.Value == m_structBT_Data.ui8FixType)
											{
												cbFixType.SelectedIndex = i;
												break;
											}
										}
										tbNumSV.Text = string.Format("{0}", m_structBT_Data.ui8NumSV);

										tbHAcc.Text = string.Format("{0}", m_structBT_Data.ui32HAcc);
										tbVAcc.Text = string.Format("{0}", m_structBT_Data.ui32VAcc);

										cbSamplePoint.Checked = (m_structBT_Data.ui8Bits & 0x01) != 0x00;
                                        rtkConnected.Checked = (m_structBT_Data.ui8Bits & 0x04) != 0x00;
                                        chineseReceiver.Checked = (m_structBT_Data.ui8Bits & 0x02) != 0x00;
                                    }
									m_eBT_State = eBT_STATE.ebtWAITING_MAGIC_NUMBER;

#if false
									System.Diagnostics.Trace.WriteLine(string.Format("{0:00}.{1:000}: BT_Data Version={2}, DateTime={3}{4}",
										DateTime.Now.Second, DateTime.Now.Millisecond, m_structBT_Data.ui8Version,
										m_structBT_Data.datTimeStamp,
										m_datLastPacket != DateTime.MinValue ? string.Format(" delay={0:0}ms", (DateTime.Now - m_datLastPacket).TotalMilliseconds) : ""));
#endif

									m_datLastPacket = DateTime.Now;
								}
								break;
						}
					}
				}
			}

			// Send LED data back to ESP via Bluetooth
			if (m_ClientStream != null && (DateTime.Now - m_datLast_Send_LEDData).TotalMilliseconds >= 100)
			{
				try
				{
					m_datLast_Send_LEDData = DateTime.Now;
					BuildLedData();
					m_ClientStream.Write(m_byteArrayLED_Data, 0, m_byteArrayLED_Data.Length);
				}
				catch (Exception)
				{
				}
			}

			if (m_cSimulator != null)
				m_cSimulator.TickTack();
		}

		private void BuildLedData()
		{
			double		dDistance = 0;
			double		dHeading = 0;
			ushort		crc;

			double.TryParse(distanceTextBox.Text, out dDistance);
			double.TryParse(headingTextBox.Text, out dHeading);

			Array.Copy(BitConverter.GetBytes(dDistance), 0, m_byteArrayLED_Data, 5, 8);
			Array.Copy(BitConverter.GetBytes(dHeading), 0, m_byteArrayLED_Data, 13, 8);

			m_byteArrayLED_Data[21] = 0x01;		// bool value (placeholder)

			crc = Crc16.CRC16_Calc(m_byteArrayLED_Data, 5 + 17, 5);
			m_byteArrayLED_Data[22] = (byte)(crc & 0xFF);
			m_byteArrayLED_Data[23] = (byte)(crc >> 8);
		}

		private void ListClients()
		{
			try
			{
				structBL structX;
				List<structBL> listNewClients;

				m_bSearching = true;

				InTheHand.Net.Sockets.BluetoothClient client = new InTheHand.Net.Sockets.BluetoothClient();
				List<string> items = new List<string>();
				InTheHand.Net.Sockets.BluetoothDeviceInfo[] devices = client.DiscoverDevicesInRange();
				listNewClients = new List<structBL>();
				structX = new structBL();
				foreach (InTheHand.Net.Sockets.BluetoothDeviceInfo d in devices)
				{
					structX.strName = d.DeviceName;
					structX.Address = d.DeviceAddress;
					structX.bConnected = d.Connected;
					listNewClients.Add(structX);
				}
				m_listNewClients = listNewClients;
			}
			catch (Exception e)
			{
				MessageBox.Show(this, "Error Search Bluetooth", e.Message, MessageBoxButtons.OK, MessageBoxIcon.Error);
            }

			m_bSearching = false;
		}

